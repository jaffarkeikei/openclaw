{
  "meta": {
    "lastTouchedVersion": "2026.3.3"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "cerebras/qwen-3-235b-a22b-instruct-2507",
        "fallbacks": ["anthropic/claude-haiku-4-5", "openai/gpt-4o-mini"]
      }
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "pairing",
      "groupPolicy": "disabled"
    },
    "telegram": {
      "botToken": "__TELEGRAM_BOT_TOKEN__",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    },
    "discord": {
      "token": "__DISCORD_BOT_TOKEN__",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "auth": {
      "mode": "token"
    }
  }
}
